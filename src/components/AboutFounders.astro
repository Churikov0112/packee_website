---
import type { Founder } from '@/lib/site';

interface Props {
  founders: Founder[];
}

const { founders } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2">
  {founders.map((founder) => (
    <article class="rounded-2xl border border-brand-navy/10 bg-white p-6 shadow-card">
      <div class="flex items-center gap-4">
        <img src={founder.photo} alt={`${founder.name} portrait`} class="h-16 w-16 rounded-full border border-brand-navy/10 object-cover" loading="lazy" />
        <div>
          <h3 class="text-lg font-bold text-brand-navy">{founder.name}</h3>
          <p class="text-sm text-brand-emerald">{founder.role}</p>
        </div>
      </div>
    </article>
  ))}
</div>
